# 部署凭据 + 集群特定值模板 —— 复制为 .env 填真实值后使用。
# .env 不进 git（根 .gitignore 的 .* 忽略）。bootstrap.sh / provision-minio.sh / mirror / patch-images.sh 自动 source deploy/.env。
#
# 真凭据 + 集群特定域名只放 .env（本地）。提交到公开仓库的脚本/values/文档不含任何公司内网域名或真实密码。

# —— 镜像仓库（mirror 脚本 + ddc/fdb YAML 的 __HARBOR__ 占位由 bootstrap sed 替换）——
HARBOR=<your-registry>/data-stack

# —— Ingress 域名 ——
INGRESS_HOST=<litefuse-host>

# —— 集群 PG（复用现有 postgres）——
PG_SUPERUSER_PASS=            # postgres 超管密码（kubectl exec 进 pod 时用）

# —— 集群 MinIO ——
MINIO_ROOT_USER=root          # root 用户名（非敏感）
MINIO_ROOT_PASS=              # root 密码
MINIO_ENDPOINT=https://<minio-endpoint>   # 外部端点；集群节点也可用 http://<minio-svc-ClusterIP>:9000

# —— MinIO litefuse 专用用户（provision-minio.sh 建，bootstrap 复用）——
LF_MINIO_AK=litefuse          # 用户名（非敏感）
LF_MINIO_SK=                  # 密码（须与 provision-minio.sh 的 LF_PASS 一致）

# —— Harbor 推送账号（mirror 脚本用，拉取匿名）——
HARBOR_USER=
HARBOR_PASS=
